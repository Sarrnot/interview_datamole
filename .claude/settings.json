{
    "$schema": "https://json.schemastore.org/claude-code-settings.json",
    "permissions": {
        "allow": [
            "Bash(pnpm --filter ./client lint)",
            "Bash(pnpm --filter ./client lint:file:*)",
            "Bash(pnpm --filter ./client typecheck)",
            "Bash(pnpm --filter ./client format)",
            "Bash(pnpm --filter ./client format:file:*)",
            "Bash(pnpm --filter ./client test:*)"
        ],
        "deny": []
    },
    "hooks": {
        "PostToolUse": [
            {
                "matcher": "Edit|Write|MultiEdit",
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/check-edited-file.sh"
                    }
                ]
            }
        ],
        "Stop": [
            {
                "hooks": [
                    {
                        "type": "command",
                        "command": "$CLAUDE_PROJECT_DIR/.claude/hooks/typecheck-all.sh"
                    }
                ]
            }
        ]
    }
}
